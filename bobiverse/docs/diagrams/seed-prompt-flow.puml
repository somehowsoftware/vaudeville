@startuml seed-prompt-flow

' The contract boundary between vaudeville-bobiverse and vaudeville-cue
' at Bob spawn. Bobiverse owns the Launcher (the file written to disk and
' redirected onto the spawned agent's stdin as its first turn by the agent
' script bobiverse launches through workmux); vaudeville-cue owns the seed
' prompt's content. The configured downstream ([spawn.downstream] command
' in vaudeville.toml, default `vv assignment-context` in CUE) is the seam
' at which the two contexts meet.

title Seed-prompt contract: bobiverse / vaudeville-cue boundary

skinparam shadowing false
skinparam roundCorner 6
skinparam defaultFontName sans-serif

skinparam package {
  BackgroundColor #f4f4f4
  BorderColor #888888
}

skinparam rectangle {
  BackgroundColor<<bobiverse>>  #d0e6f0
  BorderColor<<bobiverse>>      #2a6a85
  BackgroundColor<<cue>>        #e6dff0
  BorderColor<<cue>>            #6a4a85
  BackgroundColor<<artifact>>   #faf3e0
  BorderColor<<artifact>>       #b08a3a
  BackgroundColor<<external>>   #f0f0f0
  BorderColor<<external>>       #888888
}

package "vaudeville-bobiverse" {
  rectangle "/spawn"                      as spawn      <<bobiverse>>
  rectangle "Launcher\n.scratch/launcher-<id>.md" as launcher <<artifact>>
}

package "vaudeville-cue" {
  rectangle "vv assignment-context\n([spawn.downstream] default)" as downstream <<cue>>
}

rectangle "workmux" as workmux <<external>>
rectangle "spawned claude\n(bobiverse agent script)" as agent <<external>>

spawn      -> downstream : invoke (exec)
downstream -> spawn      : stdout = prompt body
spawn      -> launcher   : write
spawn      -> workmux    : ""workmux add --agent""\n(launch + ""--fork"")
workmux    -> agent      : launches
launcher   -> agent      : ""< launcher"" on stdin\n(first turn, never argv)

@enduml
