def _command_group(module_name):
    module = importlib.import_module(module_name)
    apps = [value for value in vars(module).values() if isinstance(value, typer.Typer)]
    if len(apps) != 1:
        raise SystemExit(
            "{{ program }}: " + module_name + " must expose exactly one Typer app to compose"
        )
    return get_command(apps[0])


class _Federation(click.CommandCollection):
    """The one flat `{{ program }}`, composed from the Contributor command groups.

    Its subcommands are the union of the groups' own, and `CommandCollection`
    owns the top-level parse, `--help`, and the unknown-subcommand error.
    `get_command` routes each subcommand through its owning group, so the group's
    root callback runs when the subcommand is invoked, and rejects a name two
    Contributors both claim.
    """

    def get_command(self, ctx, name):
        owners = [(source, source.get_command(ctx, name)) for source in self.sources]
        owners = [(source, leaf) for source, leaf in owners if leaf is not None]
        if not owners:
            return None  # click renders its own "No such command" usage error.
        if len(owners) > 1:
            return _Collision(name)
        group, leaf = owners[0]
        return _Routed(name, group, help=leaf.help)


class _Subcommand(click.Command):
    """A subcommand the Facade exposes. It carries no help option of its own and
    holds every token in `ctx.args`, so the whole tail reaches the owning group
    verbatim; each one is either _Routed (served) or a _Collision (rejected)."""

    def __init__(self, name, help=None):
        super().__init__(
            name,
            help=help,
            add_help_option=False,
            context_settings={"ignore_unknown_options": True, "allow_extra_args": True},
        )


class _Routed(_Subcommand):
    """Hands the subcommand and its tail back to the owning group, so the group's
    root callback runs before the subcommand the group owns."""

    def __init__(self, name, group, help=None):
        super().__init__(name, help=help)
        self._group = group

    def invoke(self, ctx):
        self._group.main([self.name, *ctx.args], prog_name="{{ program }}", standalone_mode=True)


class _Collision(_Subcommand):
    """A subcommand two Contributors both claim: invoking it is the federation's error."""

    def invoke(self, ctx):
        raise click.UsageError(
            "subcommand " + repr(self.name) + " is claimed by more than one Contributor; "
            "the federation collides and cannot be served"
        )


def _print_surface(ctx, param, value):
    """Emit the composed command surface as JSON for the post-deploy Surface Check."""
    if not value or ctx.resilient_parsing:
        return
    names = sorted(ctx.command.list_commands(ctx))
    colliding = [name for name in names if isinstance(ctx.command.get_command(ctx, name), _Collision)]
    if colliding:
        raise click.ClickException("subcommands claimed by more than one Contributor: " + ", ".join(colliding))
    click.echo(json.dumps(names))
    ctx.exit()


def _federation():
    groups = [_command_group(module_name) for module_name in _MODULES]
    surface = click.Option(
        ["--surface"],
        is_flag=True,
        is_eager=True,
        expose_value=False,
        hidden=True,
        callback=_print_surface,
    )
    return _Federation(sources=groups, name="{{ program }}", params=[surface])


def main() -> None:
    _federation().main(prog_name="{{ program }}")


if __name__ == "__main__":
    main()
